# Koraku SDK — copy to .env

# --- LLM (pick one provider) ---
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=your-fireworks-key
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p6

# --- Optional tools ---
EXA_API_KEY=
FIRECRAWL_API_KEY=
COMPOSIO_API_KEY=

# --- Auth for self-hosted /stream (optional) ---
# AUTH_BACKEND=none
# REQUIRE_AUTH_FOR_CHAT=false
# KORAKU_API_KEY=
# SUPABASE_JWT_SECRET=

# --- Execution ---
DEFAULT_EXECUTION_TARGET=local
MEMORY_BACKEND=filesystem
PORT=8000

# --- Composio sub-agent (default true) ---
# COMPOSIO_SUBAGENT_MODE=true
# COMPOSIO_TOOLS_LIMIT=48
