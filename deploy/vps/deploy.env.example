# Local VPS deploy config (copy to deploy.env — not committed).
# Used by: ./scripts/deploy-vps.sh
#
# CI auto-deploy uses GitHub Actions secrets instead (see deploy/vps/README.md):
#   KORAKU_VPS_HOST, KORAKU_VPS_SSH_PRIVATE_KEY, optional KORAKU_VPS_USER / KORAKU_VPS_DIR

KORAKU_VPS_HOST=your.vps.ip.or.hostname
KORAKU_VPS_USER=ubuntu
KORAKU_VPS_SSH_KEY=/path/to/your/ssh-private-key
KORAKU_VPS_DIR=/opt/koraku/koraku-cloud

# Optional overrides:
# KORAKU_VPS_COMPOSE_FILE=deploy/vps/docker-compose.yml
# KORAKU_VPS_HEALTH_URL=http://127.0.0.1:8000/health
